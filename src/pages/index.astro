---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div id="container">
    <video 
      id="video" 
      class="video-element"
      autoplay 
      playsinline 
      muted
    ></video>
    <canvas 
      id="overlay" 
      class="overlay-canvas"
    ></canvas>
    
    <!-- Hamburger Menu Toggle -->
    <button id="menuToggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
    
    <!-- Collapsible Controls Panel -->
    <div id="controls" class="collapsed">
      <h1>Tip Track</h1>
      
      <div class="control-group">
        <label for="trackingMode">Tracking Mode</label>
        <select id="trackingMode">
          <option value="hand">Hand Tracking (Demo)</option>
          <option value="pose">Pose Tracking (Full Body)</option>
        </select>
        <small class="hint">Hand: index fingertip = sword tip</small>
      </div>

      <div class="control-group">
        <label for="debugMode">Debug Mode</label>
        <select id="debugMode">
          <option value="none">Production (Trails)</option>
          <option value="landmarks">Landmarks</option>
          <option value="skeleton">Skeleton</option>
          <option value="vectors">Vectors + Grid</option>
          <option value="tips-only">Tip Points</option>
          <option value="trails-only">Trails Only</option>
          <option value="lightsaber">Lightsaber</option>
          <option value="heatmap">Heatmap</option>
          <option value="all">All Debug</option>
        </select>
      </div>

      <div class="control-group">
        <label for="trailLength">
          Trail Length: <span id="trailLengthValue">30</span>
        </label>
        <input
          type="range"
          id="trailLength"
          min="5"
          max="60"
          value="30"
          step="5"
        />
      </div>

      <div class="control-group">
        <label for="inferenceRate">
          Inference Rate: <span id="inferenceRateValue">15</span> fps
        </label>
        <input 
          type="range" 
          id="inferenceRate" 
          min="5" 
          max="30" 
          value="15" 
          step="1"
        />
      </div>

      <details class="advanced-controls">
        <summary>Advanced / Effects</summary>
        <div class="control-group">
          <label for="effectMode">Effect Mode</label>
          <select id="effectMode">
            <option value="none">None</option>
            <option value="lightsaber-glow">Lightsaber Glow</option>
            <option value="matrix">Matrix</option>
            <option value="motion-blur">Motion Blur</option>
          </select>
        </div>
        <div class="control-group">
          <label for="glowIntensity">
            Glow Intensity: <span id="glowIntensityValue">1.0</span>
          </label>
          <input 
            type="range" 
            id="glowIntensity" 
            min="0" 
            max="2" 
            value="1" 
            step="0.1"
          />
        </div>
      </details>

      <div class="control-group button-group">
        <button id="clearTrails" class="btn-secondary">Clear Trails</button>
        <button id="toggleCamera" class="btn-primary">Start Camera</button>
      </div>

      <div class="status">
        <span id="detectionStatus">Initializing...</span>
        <span id="fpsCounter">-- fps</span>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Import modules
  import {
    initDetector,
    detect,
    getTrackingMode,
    resetCurrentDetector,
    POSE_LANDMARKS,
    POSE_CONNECTIONS,
    HAND_LANDMARKS,
    HAND_CONNECTIONS
  } from '../lib/unified-detector';
  import { TrailManager } from '../lib/trail-manager';
  import { TrailRenderer, DebugRenderer } from '../lib/renderer';
  import { EffectManager, FlashEffect, ExplosionEffect } from '../lib/effects';
  import type { DebugMode, EffectMode, TrackingMode, DetectionResult } from '../types/fencing';

  // DOM Elements
  const video = document.getElementById('video') as HTMLVideoElement;
  const overlay = document.getElementById('overlay') as HTMLCanvasElement;
  const menuToggle = document.getElementById('menuToggle') as HTMLButtonElement;
  const controls = document.getElementById('controls') as HTMLDivElement;
  const trackingModeSelect = document.getElementById('trackingMode') as HTMLSelectElement;
  const debugModeSelect = document.getElementById('debugMode') as HTMLSelectElement;
  const trailLengthInput = document.getElementById('trailLength') as HTMLInputElement;
  const trailLengthValue = document.getElementById('trailLengthValue') as HTMLSpanElement;
  const inferenceRateInput = document.getElementById('inferenceRate') as HTMLInputElement;
  const inferenceRateValue = document.getElementById('inferenceRateValue') as HTMLSpanElement;
  const glowIntensityInput = document.getElementById('glowIntensity') as HTMLInputElement;
  const glowIntensityValue = document.getElementById('glowIntensityValue') as HTMLSpanElement;
  const effectModeSelect = document.getElementById('effectMode') as HTMLSelectElement;
  const clearTrailsBtn = document.getElementById('clearTrails') as HTMLButtonElement;
  const toggleCameraBtn = document.getElementById('toggleCamera') as HTMLButtonElement;
  const detectionStatus = document.getElementById('detectionStatus') as HTMLSpanElement;
  const fpsCounter = document.getElementById('fpsCounter') as HTMLSpanElement;

  // State
  let isCameraRunning = false;
  let isDetectorReady = false;
  let trackingMode: TrackingMode = 'hand';
  let debugMode: DebugMode = 'none';
  let effectMode: EffectMode = 'none';
  let inferenceFps = 15;
  let detectionInterval = 1000 / inferenceFps;
  let lastDetectionTime = 0;
  let lastRenderTime = 0;
  let frameCount = 0;
  let lastFpsTime = 0;
  let currentDetections: DetectionResult[] = [];
  let isSwitchingMode = false;

  // Managers
  const trailManager = new TrailManager({ maxLength: 30 });
  const trailRenderer = new TrailRenderer(overlay);
  const debugRenderer = new DebugRenderer(overlay);
  const effectManager = new EffectManager(overlay.getContext('2d')!);

  // Set up coordinate mappers after they're created
  function setupCoordinateMappers() {
    trailRenderer.setCoordinateMapper(mapToCanvas);
    debugRenderer.setCoordinateMapper(mapToCanvas);
  }

  // Clash detection
  let lastClashTime = 0;
  const CLASH_COOLDOWN = 1000; // Minimum ms between clash effects
  const CLASH_DISTANCE = 0.03; // Normalized distance (3% of screen) - must be very close to trigger

  // Initialize
  async function init() {
    resizeAllCanvases();

    // Handle window resize
    window.addEventListener('resize', resizeAllCanvases);

    // Handle visual viewport changes (mobile address bar, keyboard, etc.)
    if (window.visualViewport) {
      window.visualViewport.addEventListener('resize', resizeAllCanvases);
      window.visualViewport.addEventListener('scroll', resizeAllCanvases);
    }

    // Update canvas size when video metadata is loaded
    video.addEventListener('loadedmetadata', () => {
      // Force a resize after a short delay to ensure iOS has settled
      resizeAllCanvases();
      setTimeout(resizeAllCanvases, 100);
      setTimeout(resizeAllCanvases, 500);
    });

    // Also handle when video starts playing (iOS sometimes delays dimension reporting)
    video.addEventListener('playing', () => {
      resizeAllCanvases();
      setTimeout(resizeAllCanvases, 100);
    });
    
    // iOS specific: resize when video dimensions change
    video.addEventListener('resize', () => {
      resizeAllCanvases();
    });

    // Setup coordinate mappers for renderers
    setupCoordinateMappers();

    // Setup event listeners
    setupEventListeners();

    // Initialize detector with default mode (hand)
    await initializeDetector();

    // Start camera automatically
    await startCamera();
  }

  /**
   * Resize all canvases to match the container size
   * The overlay canvas covers the full viewport and we handle coordinate mapping separately
   */
  function resizeAllCanvases() {
    resizeOverlayCanvas();
    trailRenderer.resize();
    debugRenderer.resize();
  }

  /**
   * Resize overlay canvas to match the container (viewport)
   * The canvas fills the container and we handle cropping via coordinate transformation
   */
  function resizeOverlayCanvas() {
    // Use visualViewport on mobile for more accurate sizing
    const containerWidth = window.visualViewport ? window.visualViewport.width : window.innerWidth;
    const containerHeight = window.visualViewport ? window.visualViewport.height : window.innerHeight;

    overlay.width = containerWidth;
    overlay.height = containerHeight;

    // Fill the container completely
    overlay.style.width = '100%';
    overlay.style.height = '100%';
    overlay.style.left = '0';
    overlay.style.top = '0';

    // Debug logging - uncomment if needed
    // console.log('[Resize] Container:', containerWidth, 'x', containerHeight, 
    //             'Video:', video.videoWidth, 'x', video.videoHeight);
  }

  /**
   * Get the video-to-container scaling and cropping info for object-fit: cover
   * Returns scale factors and crop offsets to map video coordinates to screen coordinates
   */
  function getVideoMapping(): { 
    scaleX: number; 
    scaleY: number; 
    cropX: number; 
    cropY: number;
    videoDisplayWidth: number;
    videoDisplayHeight: number;
  } {
    // Use visualViewport on mobile for more accurate sizing
    const containerWidth = window.visualViewport ? window.visualViewport.width : window.innerWidth;
    const containerHeight = window.visualViewport ? window.visualViewport.height : window.innerHeight;
    
    // Get actual video dimensions
    const videoWidth = video.videoWidth || 1280;
    const videoHeight = video.videoHeight || 720;

    const videoAspect = videoWidth / videoHeight;
    const containerAspect = containerWidth / containerHeight;

    let scale: number;
    let cropX = 0;
    let cropY = 0;

    if (videoAspect > containerAspect) {
      // Video is wider than container - fills height, cropped on left/right
      scale = containerHeight / videoHeight;
      const displayedWidth = videoWidth * scale;
      cropX = (displayedWidth - containerWidth) / 2 / scale; // How much video is cropped on each side in video coords
    } else {
      // Video is taller than container - fills width, cropped on top/bottom
      scale = containerWidth / videoWidth;
      const displayedHeight = videoHeight * scale;
      cropY = (displayedHeight - containerHeight) / 2 / scale; // How much video is cropped on each side in video coords
    }

    return { 
      scaleX: scale, 
      scaleY: scale, 
      cropX, 
      cropY,
      videoDisplayWidth: videoWidth * scale,
      videoDisplayHeight: videoHeight * scale
    };
  }

  /**
   * Map normalized video coordinates (0-1) to canvas/screen coordinates
   * Accounts for object-fit: cover cropping - only the visible portion maps to the screen
   */
  function mapToCanvas(normX: number, normY: number): { x: number; y: number } {
    const { scaleX, scaleY, cropX, cropY } = getVideoMapping();
    const containerWidth = window.visualViewport ? window.visualViewport.width : window.innerWidth;
    const containerHeight = window.visualViewport ? window.visualViewport.height : window.innerHeight;
    const videoWidth = video.videoWidth || 1280;
    const videoHeight = video.videoHeight || 720;

    // Convert normalized to video pixel coords
    const videoX = normX * videoWidth;
    const videoY = normY * videoHeight;

    // Map to screen coordinates (accounting for the cropped-out portions)
    const screenX = (videoX - cropX) * scaleX;
    const screenY = (videoY - cropY) * scaleY;

    return { x: screenX, y: screenY };
  }

  async function initializeDetector() {
    detectionStatus.textContent = `Loading ${trackingMode} model...`;
    try {
      await initDetector(trackingMode, {
        numTargets: 2,
        minDetectionConfidence: 0.5,
        minPresenceConfidence: 0.5,
        minTrackingConfidence: 0.5,
      });
      isDetectorReady = true;
      detectionStatus.textContent = isCameraRunning ? 'Running' : 'Ready - start camera';
    } catch (err) {
      console.error('Failed to initialize detector:', err);
      detectionStatus.textContent = 'Model failed to load';
    }
  }

  function setupEventListeners() {
    // Menu toggle
    menuToggle.addEventListener('click', () => {
      controls.classList.toggle('collapsed');
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      if (!controls.contains(e.target as Node) && !menuToggle.contains(e.target as Node)) {
        controls.classList.add('collapsed');
      }
    });

    // Tracking mode switch
    trackingModeSelect.addEventListener('change', async (e) => {
      const newMode = (e.target as HTMLSelectElement).value as TrackingMode;
      if (newMode !== trackingMode && !isSwitchingMode) {
        isSwitchingMode = true;
        trackingMode = newMode;
        
        // Reset detector
        isDetectorReady = false;
        await resetCurrentDetector();
        trailManager.clear();
        currentDetections = [];
        
        // Reinitialize with new mode
        await initializeDetector();
        isSwitchingMode = false;
      }
    });

    // Debug mode
    debugModeSelect.addEventListener('change', (e) => {
      debugMode = (e.target as HTMLSelectElement).value as DebugMode;
    });

    // Trail length
    trailLengthInput.addEventListener('input', (e) => {
      const value = parseInt((e.target as HTMLInputElement).value);
      trailLengthValue.textContent = value.toString();
      trailManager.setConfig({ maxLength: value });
    });

    // Inference rate
    inferenceRateInput.addEventListener('input', (e) => {
      const value = parseInt((e.target as HTMLInputElement).value);
      inferenceRateValue.textContent = value.toString();
      inferenceFps = value;
      detectionInterval = 1000 / inferenceFps;
    });

    // Glow intensity
    if (glowIntensityInput) {
      glowIntensityInput.addEventListener('input', (e) => {
        const value = parseFloat((e.target as HTMLInputElement).value);
        glowIntensityValue.textContent = value.toFixed(1);
      });
    }

    // Effect mode
    if (effectModeSelect) {
      effectModeSelect.addEventListener('change', (e) => {
        effectMode = (e.target as HTMLSelectElement).value as EffectMode;
      });
    }

    // Clear trails
    clearTrailsBtn.addEventListener('click', () => {
      trailManager.clear();
    });

    // Toggle camera
    toggleCameraBtn.addEventListener('click', toggleCamera);
  }

  async function startCamera(): Promise<void> {
    if (isCameraRunning) return;

    try {
      const stream = await navigator.mediaDevices.getUserMedia({
        video: {
          width: { ideal: 1280 },
          height: { ideal: 720 },
          facingMode: 'user'
        },
        audio: false
      });
      video.srcObject = stream;
      await video.play();
      isCameraRunning = true;
      toggleCameraBtn.textContent = 'Stop Camera';
      detectionStatus.textContent = isDetectorReady ? 'Running' : 'Loading model...';

      // Start the main loop if not already running
      const hasActiveTrails = Array.from(trailManager.getFencers().values())
        .some(f => f.trail.length > 0);
      if (!hasActiveTrails) {
        requestAnimationFrame(loop);
      }
    } catch (err) {
      console.error('Failed to access camera:', err);
      detectionStatus.textContent = 'Camera access denied';
    }
  }

  async function stopCamera(): Promise<void> {
    if (!isCameraRunning) return;

    const stream = video.srcObject as MediaStream;
    if (stream) {
      stream.getTracks().forEach(track => track.stop());
    }
    video.srcObject = null;
    isCameraRunning = false;
    toggleCameraBtn.textContent = 'Start Camera';
    detectionStatus.textContent = isDetectorReady ? 'Ready' : 'Loading model...';
  }

  async function toggleCamera() {
    if (isCameraRunning) {
      await stopCamera();
    } else {
      await startCamera();
    }
  }

  // Main loop
  async function loop(timestamp: number) {
    // Calculate FPS
    frameCount++;
    if (timestamp - lastFpsTime >= 1000) {
      fpsCounter.textContent = `${frameCount} fps`;
      frameCount = 0;
      lastFpsTime = timestamp;
    }

    // Detection (throttled, only when camera is running)
    if (isCameraRunning && timestamp - lastDetectionTime >= detectionInterval) {
      if (isDetectorReady && video.readyState >= 2) {
        try {
          currentDetections = await detect(video, timestamp);
          const tips = new Map(currentDetections.map(d => [d.id, d.tip]));
          trailManager.updateTips(tips, timestamp);

          // Check for clash (tips close together)
          if (currentDetections.length >= 2) {
            const tip1 = currentDetections[0].tip;
            const tip2 = currentDetections[1].tip;
            const dx = tip1.x - tip2.x;
            const dy = tip1.y - tip2.y;
            const distance = Math.sqrt(dx * dx + dy * dy);

            if (distance < CLASH_DISTANCE && timestamp - lastClashTime > CLASH_COOLDOWN) {
              // Trigger flash effect
              effectManager.addEffect(new FlashEffect(1600));
              lastClashTime = timestamp;
            }
          }
        } catch (err) {
          console.error('Detection error:', err);
        }
      }
      lastDetectionTime = timestamp;
    }

    // If camera is off, fade trails gradually
    if (!isCameraRunning) {
      trailManager.fadeAllTrails();
    }

    // Rendering (60fps) - always render to show fading trails
    render(timestamp);

    // Continue loop if camera is running OR if trails are still visible
    const hasActiveTrails = Array.from(trailManager.getFencers().values())
      .some(f => f.trail.length > 0);

    if (isCameraRunning || hasActiveTrails) {
      lastRenderTime = timestamp;
      requestAnimationFrame(loop);
    }
  }

  function render(timestamp: number) {
    // Clear canvas (but preserve effects which draw on top)
    trailRenderer.clear();

    // Continue fading trails even when camera is off
    if (!isCameraRunning) {
      trailManager.fadeAllTrails();
    }

    const fencers = trailManager.getFencers();

    // Render based on debug mode
    switch (debugMode) {
      case 'none':
        trailRenderer.renderTrails(fencers);
        trailRenderer.renderTipDots(fencers);
        break;

      case 'landmarks':
        if (trackingMode === 'pose') {
          currentDetections.forEach(detection => {
            const fencer = fencers.get(detection.id);
            debugRenderer.renderLandmarks(detection.landmarks, fencer?.color ?? '#00ff00');
          });
        } else {
          currentDetections.forEach(detection => {
            const fencer = fencers.get(detection.id);
            debugRenderer.renderLandmarks(detection.landmarks, fencer?.color ?? '#00ffff');
          });
        }
        break;

      case 'skeleton':
        if (trackingMode === 'pose') {
          currentDetections.forEach(detection => {
            const fencer = fencers.get(detection.id);
            debugRenderer.renderSkeleton(detection.landmarks, POSE_CONNECTIONS, fencer?.color ?? '#00ff00');
          });
        } else {
          currentDetections.forEach(detection => {
            const fencer = fencers.get(detection.id);
            debugRenderer.renderSkeleton(detection.landmarks, HAND_CONNECTIONS, fencer?.color ?? '#00ffff');
          });
        }
        break;

      case 'vectors':
        if (trackingMode === 'pose') {
          currentDetections.forEach(detection => {
            const lm = detection.landmarks;
            const wrist = lm[POSE_LANDMARKS.RIGHT_WRIST];
            const elbow = lm[POSE_LANDMARKS.RIGHT_ELBOW];
            if (wrist && elbow && detection.tip) {
              const fencer = fencers.get(detection.id);
              if (fencer) {
                debugRenderer.renderVectors(wrist, elbow, detection.tip, fencer.color);
              }
            }
          });
        } else {
          const ctx = overlay.getContext('2d')!;
          
          ctx.save();
          currentDetections.forEach(detection => {
            const lm = detection.landmarks;
            const wrist = lm[HAND_LANDMARKS.WRIST];
            const indexMcp = lm[HAND_LANDMARKS.INDEX_FINGER_MCP];
            const tip = lm[HAND_LANDMARKS.INDEX_FINGER_TIP];
            const fencer = fencers.get(detection.id);
            
            if (wrist && indexMcp && tip && fencer) {
              // Use mapToCanvas for coordinate transformation
              const wristPos = mapToCanvas(wrist.x, wrist.y);
              const mcpPos = mapToCanvas(indexMcp.x, indexMcp.y);
              const tipPos = mapToCanvas(tip.x, tip.y);
              
              ctx.strokeStyle = '#ffff00';
              ctx.lineWidth = 3;
              ctx.beginPath();
              ctx.moveTo(wristPos.x, wristPos.y);
              ctx.lineTo(mcpPos.x, mcpPos.y);
              ctx.stroke();
              
              ctx.strokeStyle = fencer.color;
              ctx.setLineDash([5, 5]);
              ctx.beginPath();
              ctx.moveTo(mcpPos.x, mcpPos.y);
              ctx.lineTo(tipPos.x, tipPos.y);
              ctx.stroke();
              ctx.setLineDash([]);
              
              ctx.fillStyle = fencer.color;
              ctx.beginPath();
              ctx.arc(tipPos.x, tipPos.y, 6, 0, Math.PI * 2);
              ctx.fill();
            }
          });
          ctx.restore();
        }
        
        // Draw calibration grid in vectors mode to help diagnose alignment
        drawCalibrationGrid();
        break;

      case 'tips-only':
        trailRenderer.renderTipDots(fencers);
        break;

      case 'trails-only':
        trailRenderer.renderTrailsOnly(fencers);
        break;

      case 'lightsaber':
        currentDetections.forEach(detection => {
          const fencer = fencers.get(detection.id);
          if (!fencer) return;
          
          if (trackingMode === 'pose') {
            const wrist = detection.landmarks[POSE_LANDMARKS.RIGHT_WRIST];
            if (wrist && detection.tip) {
              debugRenderer.renderLightsaber(wrist, detection.tip, fencer.color);
            }
          } else {
            const indexMcp = detection.landmarks[HAND_LANDMARKS.INDEX_FINGER_MCP];
            if (indexMcp && detection.tip) {
              debugRenderer.renderLightsaber(indexMcp, detection.tip, fencer.color);
            }
          }
        });
        break;

      case 'heatmap':
        trailRenderer.renderTrails(fencers);
        break;

      case 'all':
        if (trackingMode === 'pose') {
          currentDetections.forEach(detection => {
            const fencer = fencers.get(detection.id);
            debugRenderer.renderLandmarks(detection.landmarks, fencer?.color ?? '#00ff00');
            debugRenderer.renderSkeleton(detection.landmarks, POSE_CONNECTIONS, fencer?.color ?? '#00ff00');
          });
        } else {
          currentDetections.forEach(detection => {
            const fencer = fencers.get(detection.id);
            debugRenderer.renderLandmarks(detection.landmarks, fencer?.color ?? '#00ffff');
            debugRenderer.renderSkeleton(detection.landmarks, HAND_CONNECTIONS, fencer?.color ?? '#00ffff');
          });
        }
        trailRenderer.renderTrails(fencers);
        trailRenderer.renderTipDots(fencers);
        break;
    }

    // Render any active effects on top
    // Ensure valid canvas dimensions
    const effectWidth = Math.max(1, overlay.width);
    const effectHeight = Math.max(1, overlay.height);
    effectManager.updateAndRender(timestamp, effectWidth, effectHeight);
  }

  // Draw calibration grid for debugging alignment issues
  function drawCalibrationGrid() {
    const ctx = overlay.getContext('2d')!;
    const width = overlay.width;
    const height = overlay.height;
    
    ctx.save();
    ctx.strokeStyle = 'rgba(255, 255, 255, 0.3)';
    ctx.lineWidth = 1;
    ctx.setLineDash([5, 5]);
    
    // Draw 10% grid lines
    for (let i = 1; i < 10; i++) {
      const x = (width * i) / 10;
      const y = (height * i) / 10;
      
      // Vertical lines
      ctx.beginPath();
      ctx.moveTo(x, 0);
      ctx.lineTo(x, height);
      ctx.stroke();
      
      // Horizontal lines
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(width, y);
      ctx.stroke();
    }
    
    // Draw corner markers at mapped video corners
    const tl = mapToCanvas(0, 0);
    const tr = mapToCanvas(1, 0);
    const bl = mapToCanvas(0, 1);
    const br = mapToCanvas(1, 1);
    
    ctx.strokeStyle = '#00ffff';
    ctx.lineWidth = 3;
    ctx.setLineDash([]);
    
    // Draw video bounds
    ctx.beginPath();
    ctx.moveTo(tl.x, tl.y);
    ctx.lineTo(tr.x, tr.y);
    ctx.lineTo(br.x, br.y);
    ctx.lineTo(bl.x, bl.y);
    ctx.closePath();
    ctx.stroke();
    
    // Draw corner markers
    const corners = [tl, tr, bl, br];
    corners.forEach((corner, i) => {
      ctx.fillStyle = '#00ffff';
      ctx.beginPath();
      ctx.arc(corner.x, corner.y, 8, 0, Math.PI * 2);
      ctx.fill();
      
      // Label
      ctx.fillStyle = '#ffffff';
      ctx.font = '12px monospace';
      const labels = ['TL', 'TR', 'BL', 'BR'];
      ctx.fillText(labels[i], corner.x + 10, corner.y - 10);
    });
    
    ctx.restore();
  }

  // Start initialization
  init();
</script>

<style>
  /* Use 100dvh for dynamic viewport height - handles mobile address bar properly */
  #container {
    width: 100%;
    height: 100vh; /* Fallback */
    height: 100dvh; /* Modern browsers */
    height: -webkit-fill-available; /* iOS Safari fallback */
    display: flex;
    justify-content: center;
    align-items: center;
    background: #000;
    position: fixed; /* Use fixed to ensure full coverage */
    top: 0;
    left: 0;
    overflow: hidden;
  }

  .video-element {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scaleX(-1);
  }

  .overlay-canvas {
    position: absolute;
    pointer-events: none;
    transform: scaleX(-1);
    width: 100%;
    height: 100%;
  }

  /* Hamburger Menu Toggle */
  #menuToggle {
    position: absolute;
    top: 20px;
    right: 20px;
